# ── 幣安 ───────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=true              # 正式上線改 false

# ── 風控 ───────────────────────────────────────────
MAX_POSITION_USDT=100             # 單筆最大倉位（USDT）
MAX_DAILY_LOSS=500                # 每日最大虧損（USDT）
MAX_LEVERAGE=20                   # 最高槓桿倍數
POSITION_PCT=0.02                 # 帳戶餘額比例（2%）
MAX_POSITIONS=5                   # 最多同時持倉數

# ── 告警通知 ───────────────────────────────────────
ALERT_CHAT_ID=your_telegram_user_id   # 發送通知給自己
